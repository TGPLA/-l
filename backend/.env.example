# 阅读回响后端服务环境变量配置
# 请根据实际情况修改以下配置

# ==================== 服务配置 ====================
SERVER_PORT=8080

# ==================== 数据库配置 ====================
# 连接到 1Panel 中的 MySQL 容器
# 注意：Linux Docker 环境下请使用 MySQL 容器名称，如：1Panel-mysql-OHb5
# macOS/Windows Docker Desktop 可以使用 host.docker.internal
DB_HOST=1Panel-mysql-OHb5
DB_PORT=3306
DB_USER=readrecall
DB_PASSWORD=your_password_here
DB_NAME=reading_reflection

# ==================== JWT 配置 ====================
# 请修改为随机生成的安全密钥
JWT_SECRET=your-jwt-secret-key-change-me

# ==================== 智谱 AI 配置 ====================
# 可选：默认使用内置 API Key，用户也可在设置中配置自己的 Key
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash
